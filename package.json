{
  "name": "scaffscript",
  "displayName": "ScaffScript",
  "description": "Language support for ScaffScript, a module system for GML",
  "repository": {
    "type": "git",
    "url": "https://github.com/undervolta/scaffscript-vscode"
  },
  "publisher": "undervolta",
  "version": "0.1.2",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "icon": "images/logo.png",
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "scaffscript",
        "aliases": [
          "ScaffScript",
          "scaffscript"
        ],
        "extensions": [
          ".scaff"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "scaffscript",
        "scopeName": "source.scaff",
        "path": "./syntaxes/scaffscript.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "scaffscript.runGenerate",
        "title": "ScaffScript: Generate GML from this workspace",
        "shortTitle": "Generate GML"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "scaffscript.runGenerate",
          "when": "editorLangId == scaffscript",
          "group": "navigation"
        }
      ]
    }
  },
  "activationEvents": [
    "onLanguage:scaffscript"
  ],
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
