{
  "name": "scaffscript",
  "displayName": "ScaffScript",
  "description": "Language support for ScaffScript, a module system for GML",
  "repository": {
    "type": "git",
    "url": "https://github.com/undervolta/scaffscript-vscode"
  },
  "publisher": "undervolta",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "images/logo.png",
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "scaffscript",
        "aliases": [
          "ScaffScript",
          "scaffscript"
        ],
        "extensions": [
          ".ss"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "scaffscript",
        "scopeName": "source.ss",
        "path": "./syntaxes/scaffscript.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
